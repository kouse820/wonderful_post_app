{
  "permissions": {
    "allow": [
      "Bash(ruby --version)",
      "Bash(gem list *)",
      "Bash(yarn --version)",
      "Bash(npm install *)",
      "Bash(rails *)",
      "Bash(gem install *)",
      "Bash(ruby -e \"require 'logger'; puts Logger::VERSION\")",
      "Bash(RUBYOPT='-r logger' rails *)",
      "Bash(bundle install *)",
      "Bash(bundle exec *)",
      "Bash(bundle pristine *)",
      "Bash(pg_isready)",
      "Bash(psql -U postgres -c '\\\\l')",
      "Bash(psql -c '\\\\l')",
      "Bash(psql *)",
      "Bash(RUBYOPT='-r logger' bundle exec *)",
      "Bash(DISABLE_SPRING=1 bundle exec rails db:create)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(kill %1)"
    ]
  }
}
